# Required: Google AI Studio API key (free tier, never commit the real value)
GOOGLE_API_KEY=your_api_key_here

# Optional: override the Gemini model used by all agents (default: gemini-3.1-flash-lite)
PATHPILOT_MODEL=gemini-3.1-flash-lite

# Optional: Apify API token for live job scraping (free tier, apify.com)
# When set, Discovery-agent calls relevant actor for real-world listings.
APIFY_TOKEN=your_api_key_here
